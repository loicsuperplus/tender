{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    { "source": "/api/tenders", "destination": "/api/tenders" },
    { "source": "/api/winners", "destination": "/api/winners" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
